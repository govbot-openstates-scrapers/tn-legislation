{"legislative_session": "114", "identifier": "HB 1931", "title": "Sheriffs - As introduced, prohibits the county legislative body of a county with a charter form of government from adopting a budget that reduces the budget for the sheriff below the budgeted amount for the previous fiscal year unless the reduction is approved in writing by the sheriff; authorizes a sheriff to approve or disapprove a budget amendment that would reduce personnel, operational, or capital expenditures below the level proposed by the sheriff; authorizes the county legislative body to override the sheriff's disapproval by a two-thirds vote. - Amends TCA Title 5, Chapter 1, Part 2; Title 5, Chapter 9, Part 4 and Title 8, Chapter 20, Part 1.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Sheriffs"], "abstracts": [], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-tn-114-hb1931"}], "actions": [{"description": "Filed for introduction", "date": "2026-01-22", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["filing"], "related_entities": []}, {"description": "Intro., P1C.", "date": "2026-02-02", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction"], "related_entities": []}, {"description": "Assigned to s/c Cities & Counties Subcommittee", "date": "2026-02-04", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": []}, {"description": "P2C, ref. to State & Local Government Committee", "date": "2026-02-04", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": []}, {"description": "Placed on s/c cal Cities & Counties Subcommittee for 3/4/2026", "date": "2026-02-25", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Placed on cal. State & Local Government Committee for 3/11/20